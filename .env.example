# ============================================================
# myTrader 环境配置
# ============================================================
# 复制此文件为 .env 并填写实际配置

# ============================================================
# 当前使用的数据库环境: local 或 online
# ============================================================
DB_ENV=local

# ============================================================
# 本地数据库配置（开发环境）
# ============================================================
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=3306
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=your_local_password
LOCAL_DB_NAME=mytrader

# ============================================================
# 线上数据库配置（生产环境 - 从 quant 项目迁移）
# ============================================================
ONLINE_DB_HOST=your_online_host
ONLINE_DB_PORT=3306
ONLINE_DB_USER=your_online_user
ONLINE_DB_PASSWORD=your_online_password
ONLINE_DB_NAME=trade

# ============================================================
# Tushare Token (可选)
# ============================================================
TUSHARE_TOKEN=your_tushare_token

# ============================================================
# 回测参数
# ============================================================
BACKTEST_INITIAL_CASH=1000000
BACKTEST_COMMISSION=0.0002
BACKTEST_POSITION_PCT=95

# ============================================================
# QMT数据路径 (可选)
# ============================================================
QMT_DATA_PATH=

# ============================================================
# 风控参数
# ============================================================
MAX_POSITION_PCT=0.3
MAX_SINGLE_LOSS_PCT=0.05
DEFAULT_STOP_LOSS_PCT=0.08
DEFAULT_TAKE_PROFIT_PCT=0.15
