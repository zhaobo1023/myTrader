# ============================================================
# myTrader 环境配置
# ============================================================
# 复制此文件为 .env 并填写实际配置

# ============================================================
# 当前使用的数据库环境: local 或 online
# ============================================================
DB_ENV=local

# ============================================================
# Dual-write: simultaneously write to local + Aliyun
# ============================================================
DUAL_WRITE=false
DUAL_WRITE_TARGET=online

# ============================================================
# 本地数据库配置（开发环境）
# ============================================================
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=3306
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=your_local_password
LOCAL_DB_NAME=mytrader

# ============================================================
# 线上数据库配置（生产环境 - 从 quant 项目迁移）
# ============================================================
ONLINE_DB_HOST=your_online_host
ONLINE_DB_PORT=3306
ONLINE_DB_USER=your_online_user
ONLINE_DB_PASSWORD=your_online_password
ONLINE_DB_NAME=trade

# ============================================================
# Tushare Token (可选)
# ============================================================
TUSHARE_TOKEN=your_tushare_token

# ============================================================
# 飞书 Webhook URL (用于报警通知)
# ============================================================
FEISHU_WEBHOOK_URL=

# ============================================================
# 飞书自建应用 (用于晨报/复盘自动发布到飞书文档)
# ============================================================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_FOLDER_TOKEN=

# ============================================================
# 任务调度器配置
# ============================================================
MYTRADER_ENV=local
ALERT_WEBHOOK_URL=

# ============================================================
# 回测参数
# ============================================================
BACKTEST_INITIAL_CASH=1000000
BACKTEST_COMMISSION=0.0002
BACKTEST_POSITION_PCT=95

# ============================================================
# QMT数据路径 (可选)
# ============================================================
QMT_DATA_PATH=

# ============================================================
# 风控参数
# ============================================================
MAX_POSITION_PCT=0.3
MAX_SINGLE_LOSS_PCT=0.05
DEFAULT_STOP_LOSS_PCT=0.08
DEFAULT_TAKE_PROFIT_PCT=0.15

# ============================================================
# Investment RAG - DashScope API Key (embedding + LLM + reranker)
# ============================================================
RAG_API_KEY=your_dashscope_api_key

# RAG - Embedding
RAG_EMBEDDING_MODEL=text-embedding-v4
RAG_EMBEDDING_DIMENSIONS=1024
RAG_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# RAG - LLM
RAG_LLM_MODEL=qwen3.6-plus
RAG_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# RAG - Reranker
RAG_RERANKER_MODEL=gte-reranker-v2
RAG_RERANKER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ChromaDB persistence directory (default: data/chroma_db)
CHROMA_PERSIST_DIR=

# Research documents root directory
RAG_RESEARCH_DIR=

# ============================================================
# Redis 配置
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================
# JWT 认证配置
# ============================================================
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# API 服务配置
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_DEBUG=true

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO          # DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_DIR=logs            # directory for rotating log files

# ============================================================
# Celery 配置 (异步任务队列)
# ============================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================================
# PostHog - Product Analytics (self-hosted)
# ============================================================
POSTHOG_DB_PASSWORD=posthog_secret        # PostgreSQL password for PostHog DB
POSTHOG_SECRET_KEY=change-me-in-prod      # Django secret key for PostHog backend
POSTHOG_SITE_URL=http://123.56.3.1/analytics  # Public URL of PostHog instance

# ============================================================
# WeChat2RSS 配置 (公众号数据抓取)
# ============================================================
WECHAT_RSS_DB=/root/wechat2rss/data/res.db  # wechat2rss SQLite 数据库路径（独立部署，非 docker-compose 管理）
