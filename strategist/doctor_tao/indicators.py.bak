# -*- coding: utf-8 -*-
"""
陶博士策略 - 核心指标计算

实现指标：
1. RPS (Relative Price Strength) - 截面排名分位
2. MA20/60 - 移动平均线
3. 价格分位 - 相对全市场的价格分位
4. 动量斜率 - 价格动量的线性回归斜率
"""
import pandas as pd
import numpy as np
from typing import Dict, Optional
from datetime import datetime


class IndicatorCalculator:
    """指标计算器"""

    def __init__(self):
        pass

    @staticmethod
    def calc_rps(price_df: pd.DataFrame, window: int = 250) -> pd.DataFrame:
        """
        计算 RPS (Relative Price Strength) - 截面排名分位

        RPS = 截面排名分位 / 总股票数 * 100
        例如：RPS=95 表示该股票过去250天的涨幅排名处于全市场前5%

        Args:
            price_df: DataFrame，必须包含列 ['stock_code', 'trade_date', 'close']
            window: 回看窗口天数，默认250

        Returns:
            DataFrame，索引为 (stock_code, trade_date)，值为 RPS 分位
        """
        print(f"计算 RPS (window={window})...")

        price_df = price_df.copy()
        price_df = price_df.sort_values(['stock_code', 'trade_date'])

        # 计算收益率
        price_df['pct_change'] = price_df.groupby('stock_code')['close'].pct_change()

        # 计算滚动窗口收益率
        price_df['rolling_return'] = price_df.groupby('stock_code')['pct_change'].transform(
            lambda x: x.rolling(window=window).sum()
        )

        # 每个交易日对所有股票的滚动收益率进行排名
        result_list = []

        for trade_date, group in price_df.groupby('trade_date'):
            # 计算排名
            group = group.copy()
            group['rank'] = group['rolling_return'].rank(ascending=False)
            total_stocks = len(group)

            # RPS = 排名 / 总数 * 100
            group['rps'] = (total_stocks - group['rank'] + 1) / total_stocks * 100

            result_list.append(group[['stock_code', 'trade_date', 'rps']])

        result = pd.concat(result_list, ignore_index=True)
        result = result.sort_values(['stock_code', 'trade_date'])
        result = result.reset_index(drop=True)

        print(f"  RPS 计算完成，共 {len(result)} 条记录")

        return result

    @staticmethod
    def calc_ma(price_df: pd.DataFrame, windows: list = [20, 60]) -> pd.DataFrame:
        """
        计算移动平均线 MA20, MA60

        Args:
            price_df: DataFrame，必须包含列 ['stock_code', 'trade_date', 'close']
            windows: 窗口列表，如 [20, 60]

        Returns:
            DataFrame，包含 MA20, MA60 列
        """
        print(f"计算 MA {windows}...")

        price_df = price_df.copy()
        price_df = price_df.sort_values(['stock_code', 'trade_date'])

        result = price_df[['stock_code', 'trade_date', 'close']].copy()

        for window in windows:
            col_name = f'ma{window}'
            result[col_name] = result.groupby('stock_code')['close'].transform(
                lambda x: x.rolling(window=window).mean()
            )

        print(f"  MA 计算完成")
        return result
    @staticmethod
    def calc_price_percentile(price_df: pd.DataFrame, window: int = 750) -> pd.DataFrame:
        """
        计算价格分位 - 相对全市场的价格分位

        用于判断股票处于历史高位还是低位

        Args:
            price_df: DataFrame，必须包含列 ['stock_code', 'trade_date', 'close']
            window: 回看窗口天数，默认750

        Returns:
            DataFrame，包含 price_percentile 列
        """
        print(f"计算价格分位 (window={window})...")

        price_df = price_df.copy()
        price_df = price_df.sort_values(['stock_code', 'trade_date'])

        # 计算滚动窗口内的价格分位数
        result_list = []

        for stock_code, group in price_df.groupby('stock_code'):
            group = group.sort_values('trade_date')
            prices = group['close'].values
            percentiles = []

            for i in range(len(group)):
                if i < window:
                    # 数据不足，使用全部历史数据
                    historical_prices = prices[:i+1]
                else:
                    historical_prices = prices[i-window+1:i+1]

                # 计算当前价格在历史数据中的分位数
                current_price = prices[i]
                pct = (historical_prices <= current_price).sum() / len(historical_prices) * 100
                percentiles.append(pct)

            group['price_percentile'] = percentiles
            result_list.append(group[['stock_code', 'trade_date', 'price_percentile']])

        result = pd.concat(result_list, ignore_index=True)
        result = result.sort_values(['stock_code', 'trade_date'])
        result = result.reset_index(drop=True)

        print(f"  价格分位计算完成，共 {len(result)} 条记录")
        return result
    @staticmethod
    def calc_momentum_slope(price_df: pd.DataFrame, window: int = 20) -> pd.DataFrame:
        """
        计算动量斜率 - 价格动量的线性回归斜率

        斜率 > 0 表示上涨趋势
        斜率 < 0 表示下跌趋势

        Args:
            price_df: DataFrame，必须包含列 ['stock_code', 'trade_date', 'close']
            window: 回看窗口天数,默认20

        Returns:
            DataFrame，包含 momentum_slope 列
        """
        print(f"计算动量斜率 (window={window})...")

        price_df = price_df.copy()
        price_df = price_df.sort_values(['stock_code', 'trade_date'])

        result_list = []

        for stock_code, group in price_df.groupby('stock_code'):
            group = group.sort_values('trade_date')
            prices = group['close'].values
            slopes = []

            for i in range(len(group)):
                if i < window - 1:
                    slopes.append(np.nan)
                else:
                    # 使用最近 window 天的数据进行线性回归
                    x = np.arange(window)
                    y = prices[i-window+1:i+1]

                    # 緻加趋势线
                    try:
                        # 标准化
                        x_norm = (x - x.mean()) / x.std() if x.std() > 0 else x
                        y_norm = (y - y.mean()) / y.std() if y.std() > 0 else y

                        # 线性回归
                        slope = np.polyfit(x_norm, y_norm, 1)[0]
                        slopes.append(slope)
                    except:
                        slopes.append(np.nan)

            group['momentum_slope'] = slopes
            result_list.append(group[['stock_code', 'trade_date', 'momentum_slope']])

        result = pd.concat(result_list, ignore_index=True)
        result = result.sort_values(['stock_code', 'trade_date'])
        result = result.reset_index(drop=True)

        print(f"  动量斜率计算完成，共 {len(result)} 条记录")
        return result
    @staticmethod
    def calc_all_indicators(price_df: pd.DataFrame) -> pd.DataFrame:
        """
        计算所有指标

        Args:
            price_df: DataFrame，必须包含列 ['stock_code', 'trade_date', 'close']

        Returns:
            DataFrame，包含所有指标列
        """
        print("=" * 60)
        print("开始计算所有指标...")
        print("=" * 60)

        # 确保数据排序
        price_df = price_df.copy()
        price_df = price_df.sort_values(['stock_code', 'trade_date'])

        # 1. RPS
        rps_df = IndicatorCalculator.calc_rps(price_df, window=250)

        # 2. MA20/60
        ma_df = IndicatorCalculator.calc_ma(price_df, windows=[20, 60])

        # 3. 价格分位
        price_pct_df = IndicatorCalculator.calc_price_percentile(price_df, window=750)

        # 4. 动量斜率
        slope_df = IndicatorCalculator.calc_momentum_slope(price_df, window=20)

        # 合并所有指标
        print("\n合并所有指标...")
        result = price_df[['stock_code', 'trade_date', 'close']].copy()

        # 合并 RPS
        result = result.merge(
            rps_df[['stock_code', 'trade_date', 'rps']],
            on=['stock_code', 'trade_date'],
            how='left'
        )

        # 合并 MA
        result = result.merge(
            ma_df[['stock_code', 'trade_date', 'ma20', 'ma60']],
            on=['stock_code', 'trade_date'],
            how='left'
        )

        # 合并价格分位
        result = result.merge(
            price_pct_df[['stock_code', 'trade_date', 'price_percentile']],
            on=['stock_code', 'trade_date'],
            how='left'
        )

        # 合并动量斜率
        result = result.merge(
            slope_df[['stock_code', 'trade_date', 'momentum_slope']],
            on=['stock_code', 'trade_date'],
            how='left'
        )

        print("\n" + "=" * 60)
        print("所有指标计算完成！")
        print(f"共 {len(result)} 条记录")
        print("=" * 60)

        return result


if __name__ == '__main__':
    # 测试指标计算
    from data_fetcher import DoctorTaoDataFetcher

