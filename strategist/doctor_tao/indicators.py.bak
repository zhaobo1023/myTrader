    # 计算所有指标
    result = IndicatorCalculator.calc_all_indicators(price_df)

    # 显示结果
    print("\n" + "=" * 60)
    print("指标计算结果示例:")
    print("=" * 60)
    print(result.head(10))

    # 显示 RPS 统计
    print("\nRPS 统计:")
    print(result['rps'].describe())

    # 显示动量斜率统计
    print("\n动量斜率统计:")
    print(result['momentum_slope'].describe())
